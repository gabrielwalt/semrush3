{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write|Bash",
        "hooks": [
          { "type": "command", "command": "node tools/quality/guard-hook.mjs" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          { "type": "command", "command": "node tools/quality/css-no-producer.mjs --hook" }
        ]
      }
    ]
  }
}
